{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Vajra",
  "version": "0.2.0",
  "identifier": "com.vajra.manager",
  "build": {
    "beforeDevCommand": "node scripts/build-sidecar.mjs && npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "node scripts/build-sidecar.mjs && npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Vajra",
        "width": 960,
        "height": 640,
        "minWidth": 700,
        "minHeight": 440,
        "decorations": false,
        "transparent": false,
        "center": true,
        "resizable": true
      }
    ],
    "security": {
      "csp": "default-src 'self'; connect-src ipc: http://ipc.localhost http://localhost:* http://127.0.0.1:*; img-src 'self' data: asset: http://asset.localhost blob:; style-src 'self' 'unsafe-inline'; script-src 'self'"
    }
  },
  "bundle": {
    "active": true,
    "targets": ["msi", "nsis", "deb", "appimage", "dmg"],
    "license": "assets/license.txt",
    "windows": {
      "nsis": {
        "headerImage": "assets/header.bmp",
        "sidebarImage": "assets/sidebar.bmp",
        "installMode": "perMachine",
        "installerHooks": "assets/nsis-hooks.nsh"
      }
    },
    "externalBin": ["bin/vajrad", "bin/vajra"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  },
  "plugins": {
    "deep-link": {
      "mobile": [],
      "desktop": {
        "schemes": ["vajra"]
      }
    },
    "updater": {
      "endpoints": [
        "https://github.com/msmayanksingh22/Vajra-Download-Manager/releases/latest/download/latest.json"
      ],
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IEUzOTVBQjJEMENEQjU0NTcKUldSWFZOc01MYXVWNHlQdVRZRmpzRlJSMWU5OWx1bVZDM0FiYUNHalBJQVFTUmxneVVIblQyWnQK"
    }
  }
}
