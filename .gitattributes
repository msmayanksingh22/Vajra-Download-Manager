# Auto-detect text files and normalize line endings to LF in the repo
* text=auto eol=lf

# Windows-specific scripts keep CRLF
*.bat text eol=crlf
*.ps1 text eol=crlf
*.cmd text eol=crlf

# Binaries
*.png binary
*.jpg binary
*.jpeg binary
*.ico binary
*.icns binary
*.bmp binary
*.gif binary
*.webp binary
*.exe binary
*.dll binary
*.so binary
*.dylib binary
*.msi binary
*.deb binary
*.dmg binary
*.pdb binary
*.rlib binary
Cargo.lock -diff
